---
// VoicePrompt.astro — Language selection screen
---
<div id="voice-prompt-overlay" role="dialog" aria-modal="true" aria-label="Language selection">
  <div class="vp-inner">
    <div class="vp-cross" aria-hidden="true">☨</div>
    <h1 class="vp-title">Rosari</h1>
    <p class="vp-subtitle">The Holy Rosary</p>

    <div class="vp-text-row">
      <input
        id="language-text-input"
        type="text"
        placeholder="Filipino, Tagalog, English…"
        autocomplete="new-password"
        spellcheck="false"
        inputmode="text"
        aria-label="Type your language"
      />
      <button id="language-text-submit" class="vp-go-btn" aria-label="Begin">Begin</button>
    </div>

    <p class="vp-hint">Type any language — your tongue, your prayer.</p>
  </div>
</div>

<!-- Resume Banner (returning users) -->
<div id="resume-banner" style="display:none;" role="dialog" aria-label="Resume previous session">
  <div class="resume-inner">
    <p>Welcome back. Continue in <strong class="resume-lang"></strong>?</p>
    <div class="resume-btns">
      <button id="resume-yes-btn" class="btn-gold">Yes, begin</button>
      <button id="resume-no-btn" class="btn-ghost">Choose language</button>
    </div>
  </div>
</div>

<script>
  document.getElementById('language-text-input')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') document.getElementById('language-text-submit')?.click();
  });
</script>

<style>
  #voice-prompt-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: radial-gradient(ellipse at center, #0d0b06 0%, #040302 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    animation: fadeIn 1.2s ease forwards;
  }

  .vp-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(1.2rem, 4vh, 2rem);
    max-width: 560px;
    width: 100%;
    text-align: center;
    animation: fadeInUp 1s ease forwards;
  }

  .vp-cross {
    font-size: clamp(2.8rem, 8vw, 4rem);
    color: var(--gold);
    text-shadow: 0 0 24px var(--gold-glow);
    line-height: 1;
  }

  .vp-title {
    font-family: 'Cinzel', Georgia, serif;
    font-size: clamp(4rem, 18vw, 7rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--gold-light);
    text-shadow: 0 0 40px var(--gold-glow), 0 2px 4px rgba(0,0,0,0.8);
    margin: 0;
    line-height: 1;
  }

  .vp-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(1.2rem, 4vw, 1.6rem);
    color: var(--text-dim);
    letter-spacing: 0.08em;
    margin-top: -0.5rem;
  }

  .vp-text-row {
    display: flex;
    gap: 0.6rem;
    width: 100%;
    max-width: 520px;
  }

  /* – Language Input ––––––––––––––––––––––––––––––––––––– */
  #language-text-input {
    flex: 1;
    padding: clamp(0.8rem, 2.5vw, 1.1rem) clamp(1rem, 3vw, 1.4rem);
    border: 2px solid var(--gold-dim);
    border-radius: 6px;
    background: rgba(201, 168, 76, 0.10);
    color: #f5d06e;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.3rem, 4.5vw, 1.8rem);
    outline: none;
    letter-spacing: 0.02em;
    caret-color: #f5d06e;
    /* These two lines override ANY browser/iOS autofill dark text */
    -webkit-text-fill-color: #f5d06e;
    transition: border-color 0.2s, background 0.2s;
  }

  #language-text-input::placeholder {
    color: rgba(160, 144, 112, 0.7);
    opacity: 1;
    -webkit-text-fill-color: rgba(160, 144, 112, 0.7);
  }

  #language-text-input:focus {
    border-color: var(--gold);
    background: rgba(201, 168, 76, 0.16);
    box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.18);
  }

  /* Fix Chrome/Safari autofill overriding text color with dark background */
  #language-text-input:-webkit-autofill,
  #language-text-input:-webkit-autofill:hover,
  #language-text-input:-webkit-autofill:focus {
    -webkit-text-fill-color: #f5d06e !important;
    -webkit-box-shadow: 0 0 0px 1000px #0d0b06 inset !important;
    caret-color: #f5d06e;
  }

  /* – Begin Button –––––––––––––––––––––––––––––––– */
  .vp-go-btn {
    padding: clamp(0.8rem, 2.5vw, 1.1rem) clamp(1.2rem, 4vw, 2rem);
    background: var(--gold-dim);
    color: var(--bg);
    border-radius: 6px;
    font-family: 'Cinzel', serif;
    font-size: clamp(1rem, 3vw, 1.3rem);
    font-weight: 600;
    letter-spacing: 0.08em;
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .vp-go-btn:hover { background: var(--gold); transform: scale(1.03); }
  .vp-go-btn:active { transform: scale(0.97); }

  /* – Hint –––––––––––––––––––––––––––––––––––––– */
  .vp-hint {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(1.1rem, 4vw, 1.5rem);
    color: var(--gold-light);
    line-height: 1.5;
    opacity: 0.85;
    letter-spacing: 0.02em;
  }

  /* – Resume banner –––––––––––––––––––––––––––––––– */
  #resume-banner {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    background: var(--bg-glass);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    padding: 1rem;
    animation: fadeInUp 0.5s ease;
  }

  .resume-inner {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 1rem;
    color: var(--text-dim);
  }

  .resume-btns { display: flex; gap: 0.5rem; }

  .btn-gold {
    padding: 0.5rem 1.2rem;
    background: var(--gold-dim);
    color: var(--bg);
    border-radius: 4px;
    font-family: 'Cinzel', serif;
    font-size: 0.9rem;
    font-weight: 600;
    transition: background 0.2s;
  }
  .btn-gold:hover { background: var(--gold); }

  .btn-ghost {
    padding: 0.5rem 1rem;
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border-dim);
    border-radius: 4px;
    font-size: 0.9rem;
    transition: all 0.2s;
  }
  .btn-ghost:hover { border-color: var(--border); color: var(--text-dim); }
</style>
